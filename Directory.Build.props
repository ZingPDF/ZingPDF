<Project>
  <PropertyGroup>
    <VersionPrefix>0.1</VersionPrefix>
    <VersionBase>$(VersionPrefix).0</VersionBase>
    <Version Condition="'$(Version)' == ''">$(VersionBase)-dev</Version>
    <AssemblyVersion Condition="'$(AssemblyVersion)' == ''">$(VersionBase).0</AssemblyVersion>
    <FileVersion Condition="'$(FileVersion)' == ''">$(VersionBase).0</FileVersion>
    <InformationalVersion Condition="'$(InformationalVersion)' == ''">$(Version)</InformationalVersion>
  </PropertyGroup>
</Project>
